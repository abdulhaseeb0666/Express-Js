<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body class="bg-black">
    <%- include('partials/navbar') %>

        <% if(!users || users.length == 0){ %>
            <h1 class="text-white font-bold text-center mt-10"> No Users Found <br>
                <a href="/add-user" class="text-blue-500 text-underlined font-medium">Click</a> to add User </h1>
        <%  } else { %>
            <!-- Users -->
            <div class="bg-gray-800 w-[95vw] h-fit flex flex-wrap m-5 border-2 border-white rounded-2xl flex p-5 gap-5   ">
                <% users.forEach((user) => { %>
                    <div class="bg-gray-700 flex flex-col h-50 w-54 justify-between p-2 rounded-xl border-2 border-black shadow-2xl text-center text-white">
                        <p class="font-bold text-xl ">
                            <%= user.first_name + " " + user.last_name %>
                        </p>
                        <p class="text-ls text-gray-400 font-semibold text-wrap">
                            <%= user.email %>
                        </p>
                        <p class="text-md ">
                            <%= user.phone %>
                        </p>
                        <p class="text-sm">
                            <%= user.address %>
                        </p>
                        <div class="flex justify-between w-full">
                            <a class="bg-red-800 border-2 border-white px-2 py-1 rounded-xl " href="/delete-user/<%= user._id %>">
                                Delete
                            </a>
                            <a class="bg-yellow-700 border-2 border-white px-2 py-1 rounded-xl " href="/update-user/<%= user._id %>">
                                Update
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
            <!-- Pagination -->
            <div class="flex items-center justify-between border-t border-white/10 px-4 py-3 sm:px-6">
                <div class="flex flex-1 justify-between sm:hidden">
                    <a href="#" class="relative inline-flex items-center rounded-md border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-gray-200 hover:bg-white/10">Previous</a>
                    <a href="#" class="relative ml-3 inline-flex items-center rounded-md border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-gray-200 hover:bg-white/10">Next</a>
                </div>
                <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-center">
                    <div>
                        <nav aria-label="Pagination" class="isolate inline-flex -space-x-px rounded-md">
                            <!-- PREVIOUS BUTTON -->
                            <a 
                                href="<%= hasPrevPage ? `/?page=${prevPage}` : '#' %>" 
                                class="relative inline-flex items-center rounded-l-md px-2 py-2 
                                <%= hasPrevPage ? 'text-gray-400 hover:bg-white/5' : 'text-gray-600 cursor-not-allowed' %> 
                                inset-ring inset-ring-gray-700 focus:z-20 focus:outline-offset-0"
                            >
                                <span class="sr-only">Previous</span>
                                <svg viewBox="0 0 20 20" fill="currentColor" class="size-5">
                                <path d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z"/>
                                </svg>
                            </a>

                            <!-- PAGE NUMBERS -->
                            <% for(let i = 1; i <= totalPages; i++){ %>
                                <a 
                                href="/?page=<%= i %>" 
                                class="relative inline-flex items-center px-4 py-2 text-sm font-semibold 
                                <%= i === page 
                                    ? 'bg-blue-500 text-white z-10' 
                                    : 'text-gray-200 inset-ring inset-ring-gray-700 hover:bg-white/5' %> 
                                focus:z-20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
                                >
                                <%= i %>
                                </a>
                            <% } %>

                            <!-- NEXT BUTTON -->
                            <a 
                                href="<%= hasNextPage ? `/?page=${nextPage}` : '#' %>" 
                                class="relative inline-flex items-center rounded-r-md px-2 py-2 
                                <%= hasNextPage ? 'text-gray-400 hover:bg-white/5' : 'text-gray-600 cursor-not-allowed' %> 
                                inset-ring inset-ring-gray-700 focus:z-20 focus:outline-offset-0"
                            >
                                <span class="sr-only">Next</span>
                                <svg viewBox="0 0 20 20" fill="currentColor" class="size-5">
                                <path d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z"/>
                                </svg>
                            </a>
                        </nav>
                    </div>
                </div>
            </div>
        <%   } %>
</body>

</html>