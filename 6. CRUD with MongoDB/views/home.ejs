<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body class="bg-black">
    <%- include('partials/navbar') %>

    <div class="bg-gray-800 w-[95vw] h-screen m-5 border-2 border-white rounded-2xl flex p-5 gap-5   ">
        <% users.forEach((user) => { %>
            <div class="bg-gray-700 flex flex-col h-50 w-50 justify-between p-2 rounded-xl border-2 border-black shadow-2xl text-center text-white" >
                <p class="font-bold text-xl " ><%= user.first_name + " " + user.last_name %></p>
                <p class="text-ls text-gray-400 font-semibold"><%= user.email %></p>
                <p class="text-md "><%= user.phone %></p>
                <p class="text-sm"><%= user.address %></p>
                <div class="flex justify-between w-full">
                    <a class="bg-red-800 border-2 border-white px-2 py-1 rounded-xl " href="/delete-user/<%= user._id %>">
                        Delete
                    </a>
                    <a class="bg-yellow-700 border-2 border-white px-2 py-1 rounded-xl " href="/update-user/<%= user._id %>">
                        Update
                    </a>
                </div>
                
            </div>
        <% }) %>
    </div>
</body>
</html>